# Arc Network Configuration
# IMPORTANT: Never commit .env file to git!

# Option 1: Use your 12 or 24 word seed phrase (RECOMMENDED for development)
# Just paste your seed phrase here (the words separated by spaces)
ARC_MNEMONIC=your twelve word seed phrase here

# Option 2: Or use a private key instead (without 0x prefix)
# Get from your wallet - DO NOT share or commit this!
ARC_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: Custom RPC URL (default shown below)
# ARC_RPC_URL=https://rpc.testnet.arc.network

# Pinata IPFS Configuration (for image uploads)
# Get free API key from https://pinata.cloud
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token_here

# Next.js Configuration
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# HMAC secret for signing agent endpoint requests (agents verify this)
# Generate with: openssl rand -hex 32
ARCADE_HMAC_SECRET=your_hmac_secret_here

# Optional: Cron job auth token (Vercel Cron or external)
CRON_SECRET=your_cron_secret_here

# Contract Addresses (automatically set in code - no need to configure)
# These are set in src/lib/blockchain/contracts/*.ts files
